# ============================================
# SF8 Environment Variables
# ============================================

# Qwen AI API (Optional - app works without it)
# Get from: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxx

# App Configuration
VITE_APP_NAME=SF8 - AI Customer Behavior Prediction
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_QWEN=true
VITE_ENABLE_SIMULATION=true

# Demo Mode (always true for PoC)
VITE_DEMO_MODE=true
